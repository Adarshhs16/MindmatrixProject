<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_large"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Strength Map"
        android:textSize="@dimen/text_size_h2"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="@dimen/margin_extra_large"/>

    <!-- Science Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_medium"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Science"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_size_body"/>
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/sciProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:progress="0"
                app:trackThickness="10dp"
                app:trackCornerRadius="5dp"
                app:indicatorColor="@color/science_blue"/>
            <TextView
                android:id="@+id/sciPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_size_small"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Math Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_medium"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mathematics"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_size_body"/>
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/mathProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:progress="0"
                app:trackThickness="10dp"
                app:trackCornerRadius="5dp"
                app:indicatorColor="@color/math_purple"/>
            <TextView
                android:id="@+id/mathPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_size_small"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Social Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_medium"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Social Science"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_size_body"/>
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/socProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:progress="0"
                app:trackThickness="10dp"
                app:trackCornerRadius="5dp"
                app:indicatorColor="@color/social_orange"/>
            <TextView
                android:id="@+id/socPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_size_small"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
